{
  "name": "collecta",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:web": "bun --cwd apps/web dev",
    "dev:api": "bun --cwd apps/api dev",
    "dev": "bun run dev:api & bun run dev:web",
    "typecheck": "bun run typecheck:api && bun run typecheck:web",
    "typecheck:api": "bun --cwd apps/api typecheck",
    "typecheck:web": "bun --cwd apps/web typecheck",
    "lint": "bun --cwd apps/web lint",
    "setup:env": "./scripts/setup-env.sh",
    "setup": "./scripts/setup.sh",
    "clean": "./scripts/clean.sh all",
    "clean:api": "./scripts/clean.sh api",
    "clean:web": "./scripts/clean.sh web",
    "clean:db": "./scripts/clean.sh db",
    "clean:docker": "./scripts/clean.sh docker",
    "up": "./scripts/up.sh",
    "down": "./scripts/down.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun --cwd packages/db seed"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5"
  },
  "dependencies": {
    "jose": "^6.2.3",
    "web": "^0.0.2"
  }
}
