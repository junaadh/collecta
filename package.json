{
  "name": "collecta",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:web": "./scripts/run-workspace.sh @collecta/web apps/web dev",
    "dev:api": "./scripts/run-ts.sh --watch apps/api/src/index.ts",
    "dev": "./scripts/dev.sh",
    "typecheck": "./scripts/run-workspace.sh @collecta/api apps/api typecheck && ./scripts/run-workspace.sh @collecta/web apps/web typecheck",
    "typecheck:api": "./scripts/run-workspace.sh @collecta/api apps/api typecheck",
    "typecheck:web": "./scripts/run-workspace.sh @collecta/web apps/web typecheck",
    "lint": "./scripts/run-workspace.sh @collecta/web apps/web lint",
    "setup:env": "./scripts/setup-env.sh",
    "setup": "./scripts/setup.sh",
    "clean": "./scripts/clean.sh all",
    "clean:api": "./scripts/clean.sh api",
    "clean:web": "./scripts/clean.sh web",
    "clean:db": "./scripts/clean.sh db",
    "clean:docker": "./scripts/clean.sh docker",
    "up": "./scripts/up.sh",
    "down": "./scripts/down.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "./scripts/run-ts.sh packages/db/seed.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4",
    "typescript": "^5"
  },
  "dependencies": {
    "jose": "^6.2.3",
    "web": "^0.0.2"
  }
}
